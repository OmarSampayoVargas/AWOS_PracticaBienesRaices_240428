extends ../layout/index

block contenido
  .py-10
    h1.text-4xl.my-10.font-extrabold.text-center.text-orange-400
      | Bienes
      span.font-normal.text-black  Raíces 240428

    h2.text-center.text-2xl.font-normal.text-black Ingresa tu nueva contraseña

    .mt-8.mx-auto.max-w-xl
      .bg-white.py-8.px-4.shadow-2xl.rounded-2xl

        if errores && errores.length
          ul.px-5.pb-3
            each e in errores
              li.text-red-600.text-sm.font-semibold= e.msg

        form.space-y-5(method="POST" action="" noValidate)
          input(type="hidden" name="_csrf" value=csrfToken)

          div.px-5
            label.block.text-sm.uppercase.text-gray-500.mb-2.font-bold(for="passwordUsuario") Nueva contraseña:
            input#passwordUsuario.w-full.border.border-gray-300.px-3.py-2.rounded-xl.placeholder-gray-400(
              type="password"
              name="passwordUsuario"
              placeholder="Ingresa tu nueva contraseña"
              class="hover:inset-shadow-sm focus:inset-shadow-xl focus:inset-shadow-orange-300 focus:outline-none"
            )

          div.px-5
            label.block.text-sm.uppercase.text-gray-500.mb-2.font-bold(for="confirmarPasswordUsuario") Confirmar contraseña:
            input#confirmarPasswordUsuario.w-full.border.border-gray-300.px-3.py-2.rounded-xl.placeholder-gray-400(
              type="password"
              name="confirmarPasswordUsuario"
              placeholder="Confirma tu nueva contraseña"
              class="hover:inset-shadow-sm focus:inset-shadow-xl focus:inset-shadow-orange-300 focus:outline-none"
            )

          div.flex.justify-center.py-6
            input(
              class="w-3/4 bg-gray-300 text-orange-400 hover:bg-orange-400 hover:text-white font-bold py-3 cursor-pointer rounded-4xl shadow-lg uppercase transition-all duration-200 text-center"
              type="submit"
              value="Guardar nueva contraseña"
            )

          div.flex.items-center.justify-between.pt-3.px-5
            a(
              class="text-gray-500 text-sm hover:decoration-orange-400 hover:underline transition decoration-2"
              href="/auth/login"
            ) ¿Ya tienes cuenta? Inicia Sesión

            a(
              class="text-gray-500 text-sm hover:decoration-orange-400 hover:underline transition decoration-2"
              href="/auth/registro"
            ) ¿No tienes cuenta? Regístrate