extends ../layout/index

block contenido
  .py-10
    h1.text-4xl.my-10.font-extrabold.text-center.text-orange-400
      | Bienes
      span.font-normal.text-black  Raíces 240428

    .mt-8.mx-auto.max-w-xl
      .bg-white.py-10.px-8.shadow-2xl.rounded-2xl.text-center

        if title
          h2.text-2xl.font-bold.mb-4.text-gray-800= title
        else
          h2.text-2xl.font-bold.mb-4.text-gray-800 Mensaje

        if msg
          p.text-gray-700.mb-6= msg
        else
          p.text-gray-500.mb-6 No hay información disponible.

        if buttonVisibility
          a(
            href=buttonURL
            class="inline-block bg-orange-400 hover:bg-orange-500 text-white font-bold py-2 px-6 rounded-lg transition"
          )= buttonText
        else
          a(
            href="/auth/login"
            class="inline-block bg-orange-400 hover:bg-orange-500 text-white font-bold py-2 px-6 rounded-lg transition"
          ) Iniciar sesión